                </div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer flex justify-between items-center">
                  <span>as Columns</span>
                  <span className="text-white/50 text-xs">⌘3</span>
                </div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer flex justify-between items-center">
                  <span>as Gallery</span>
                  <span className="text-white/50 text-xs">⌘4</span>
                </div>
                <div className="h-px bg-white/10 my-1"></div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer flex justify-between items-center">
                  <span>Use Stacks</span>
                  <span className="text-white/50 text-xs">⌃⌘0</span>
                </div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer">Clean Up</div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer flex justify-between items-center">
                  <span>Clean Up By</span>
                  <span className="text-white/50">›</span>
                </div>
                <div className="h-px bg-white/10 my-1"></div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer flex justify-between items-center">
                  <span>Hide Sidebar</span>
                  <span className="text-white/50 text-xs">⌥⌘S</span>
                </div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer flex justify-between items-center">
                  <span>Show Preview</span>
                  <span className="text-white/50 text-xs">⇧⌘P</span>
                </div>
                <div className="h-px bg-white/10 my-1"></div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer flex justify-between items-center">
                  <span>Show View Options</span>
                  <span className="text-white/50 text-xs">⌘J</span>
                </div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer">Show Status Bar</div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer">Show Path Bar</div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer">Show Tab Bar</div>
                <div className="h-px bg-white/10 my-1"></div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer">Hide Toolbar</div>
                <div className="px-4 py-2 text-white hover:bg-blue-500 cursor-pointer">Customize Toolbar...</div>
              </div>
            </>
